# Supabase Cloud — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only — requerido para subir comprobantes en /reservar/[slug]
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Opcional en Vercel si usas dominio propio (si no, usa VERCEL_URL automático)
# NEXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app

# Web Push — generar con: node scripts/generate-vapid-keys.mjs
# En Vercel: agrega las 3 y REDESPLEGA el proyecto
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu@correo.com
# Opcional (legacy): NEXT_PUBLIC_VAPID_PUBLIC_KEY mismo valor que VAPID_PUBLIC_KEY

# App local: npm run dev → http://localhost:3004
